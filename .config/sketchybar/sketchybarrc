#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
CONFIG_DIR="${CONFIG_DIR:-$SCRIPT_DIR}"
PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"
CMUX_BIN="${CMUX_BIN:-$HOME/.local/bin/cmux}"
if [[ ! -x "$CMUX_BIN" ]]; then
  CMUX_BIN="/Applications/cmux.app/Contents/Resources/bin/cmux"
fi
export CMUX_BIN
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/theme.sh"

# Density profile:
# If DELL is connected, prefer compact globally to avoid overlap.
ALL_MONITORS="$(aerospace list-monitors 2>/dev/null || true)"
if echo "$ALL_MONITORS" | rg -q "DELL P2723QE"; then
  apply_density_profile compact
else
  apply_density_profile comfortable
fi

# Main display ID for items that should stay off DELL.
# Falls back to 1 when monitor name is not found.
MAIN_DISPLAY_ID="$(echo "$ALL_MONITORS" | awk -F'|' '/LG HDR 4K/{gsub(/ /,"",$1); print $1; exit}')"
MAIN_DISPLAY_ID="${MAIN_DISPLAY_ID:-1}"

BAR=(
  position=top
  height="$BAR_HEIGHT"
  margin="$BAR_MARGIN"
  y_offset="$BAR_Y_OFFSET"
  corner_radius="$BAR_CORNER_RADIUS"
  border_width="$BAR_BORDER_WIDTH"
  blur_radius="$BAR_BLUR_RADIUS"
  padding_left="$BAR_PADDING_LEFT"
  padding_right="$BAR_PADDING_RIGHT"
)

if [[ -n "${BACKGROUND_DARKEST:-}" && -n "${CYAN:-}" ]]; then
  BAR+=(color="$(set_alpha "$BACKGROUND_DARKEST" "$BAR_COLOR_ALPHA")")
  BAR+=(border_color="$(set_alpha "$CYAN" "$BAR_BORDER_ALPHA")")
else
  BAR+=(color=0xCC1D2021)
  BAR+=(border_color=0xCC89B482)
fi

sketchybar --bar "${BAR[@]}"

# Default appearance (match main sketchybarrc)
DEFAULT=(
  background.height="$DEFAULT_BG_HEIGHT"
  background.y_offset="$DEFAULT_BG_Y_OFFSET"
  background.padding_left="$DEFAULT_BG_PADDING_LEFT"
  background.padding_right="$DEFAULT_BG_PADDING_RIGHT"
  background.corner_radius="$DEFAULT_BG_CORNER_RADIUS"
  background.border_width="$DEFAULT_BG_BORDER_WIDTH"
  label.font="$FONT"
  label.padding_left=0
  label.padding_right=0
  icon.font="$FONT"
  icon.padding_left=0
  icon.padding_right=0
)
DEFAULT_COLORS=(
  background.color="$(set_alpha "$BLACK" "$DEFAULT_BG_ALPHA")"
  label.color="$TEXT_DEFAULT"
  icon.color="$TEXT_DEFAULT"
)

sketchybar --default "${DEFAULT[@]}" "${DEFAULT_COLORS[@]}"

# Events
sketchybar --add event aerospace_workspace_change

render() {
  # 0: always on active display.
  # 1/2/3: active display only, but hidden when DELL is focused.
  if [[ "$1" == "0" ]]; then
    "$PLUGIN_DIR/transparent.lua" "$1" right active normal
  else
    "$PLUGIN_DIR/transparent.lua" "$1" right active hide_on_dell
  fi
}

if [[ -f "$ITEM_DIR/front_app.sh" ]]; then
  source "$ITEM_DIR/front_app.sh"
fi

if [[ -f "$ITEM_DIR/timestamp.sh" ]]; then
  source "$ITEM_DIR/timestamp.sh"
fi

render 0

if [[ -f "$ITEM_DIR/weather.sh" ]]; then
  source "$ITEM_DIR/weather.sh"
fi

render 1

if [[ -f "$ITEM_DIR/battery.sh" ]]; then
  source "$ITEM_DIR/battery.sh"
fi

if [[ -f "$ITEM_DIR/volume.sh" ]]; then
  source "$ITEM_DIR/volume.sh"
fi

if [[ -f "$ITEM_DIR/cafe.sh" ]]; then
  source "$ITEM_DIR/cafe.sh"
fi

if [[ -f "$ITEM_DIR/system.sh" ]]; then
  source "$ITEM_DIR/system.sh"
fi

render 2

if [[ -f "$ITEM_DIR/things.sh" ]]; then
  source "$ITEM_DIR/things.sh"
fi

render 3

if [[ -f "$ITEM_DIR/pomodoro.sh" ]]; then
  source "$ITEM_DIR/pomodoro.sh"
fi

render 4

if [[ -f "$ITEM_DIR/workspaces.sh" ]]; then
  source "$ITEM_DIR/workspaces.sh"
fi

# right-aligned internal order for system group (visual: cafe -> volume -> battery)
sketchybar --move lua.battery before lua.volume
sketchybar --move lua.volume before lua.cafe

# Outer group border for right-side cluster (pomodoro -> timestamp)
sketchybar --add bracket lua.right_cluster \
  lua.pomodoro_break \
  lua.pomodoro_work \
  lua.things \
  lua.cafe \
  lua.volume \
  lua.battery \
  lua.weather \
  lua.timestamp.date \
  lua.timestamp.time \
  --set lua.right_cluster \
  drawing=on \
  display="$MAIN_DISPLAY_ID" \
  padding_left="$OUTER_PADDING" \
  padding_right="$OUTER_PADDING" \
  background.drawing=on \
  background.color=0x00000000 \
  background.corner_radius="$PILL_CORNER_RADIUS" \
  background.border_width=0 \
  background.y_offset="$PILL_Y_OFFSET"

sketchybar --update
