#!/usr/bin/env bash

set -u

DAEMON_SCRIPT="$HOME/.config/sketchybar/helpers/calendar_daemon.sh"
PID_FILE="/tmp/sketchybar_todays_daemon.pid"
CACHE_FILE="/tmp/sketchybar_todays.cache"
LOG_FILE="/tmp/sketchybar_todays_daemon.log"

usage() {
  cat <<'USAGE'
Usage: todays-daemon <run|start|stop|restart|status|cache|tail>

Commands:
  run      Run daemon in foreground (for debugging)
  start    Start daemon in background (logs to /tmp/sketchybar_todays_daemon.log)
  stop     Stop daemon and remove pid file
  restart  Restart daemon
  status   Show daemon pid/alive status
  cache    Print cache file contents
  tail     Tail daemon log file
USAGE
}

alive() {
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    echo "alive:$pid"
    return 0
  fi
  echo "dead"
  return 1
}

run_fg() {
  if [ ! -x "$DAEMON_SCRIPT" ]; then
    echo "daemon script not executable: $DAEMON_SCRIPT" >&2
    exit 1
  fi
  exec /bin/bash "$DAEMON_SCRIPT"
}

start_bg() {
  if [ ! -x "$DAEMON_SCRIPT" ]; then
    echo "daemon script not executable: $DAEMON_SCRIPT" >&2
    exit 1
  fi

  if alive >/dev/null; then
    echo "already running ($(cat "$PID_FILE"))"
    exit 0
  fi

  nohup /bin/bash "$DAEMON_SCRIPT" >>"$LOG_FILE" 2>&1 &
  sleep 0.2
  alive || true
}

stop_bg() {
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    for _ in 1 2 3 4 5; do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
  fi
  rm -f "$PID_FILE"
  echo "stopped"
}

show_status() {
  alive || true
  if [ -f "$PID_FILE" ]; then
    echo "pid_file:$(cat "$PID_FILE" 2>/dev/null || true)"
  else
    echo "pid_file:(missing)"
  fi
  if [ -f "$CACHE_FILE" ]; then
    echo "cache:$CACHE_FILE"
    sed -n '1,12p' "$CACHE_FILE"
  else
    echo "cache:(missing)"
  fi
}

show_cache() {
  if [ -f "$CACHE_FILE" ]; then
    sed -n '1,80p' "$CACHE_FILE"
  else
    echo "cache missing: $CACHE_FILE"
    exit 1
  fi
}

cmd="${1:-status}"
case "$cmd" in
  run) run_fg ;;
  start) start_bg ;;
  stop) stop_bg ;;
  restart) stop_bg; start_bg ;;
  status) show_status ;;
  cache) show_cache ;;
  tail) tail -f "$LOG_FILE" ;;
  -h|--help|help) usage ;;
  *)
    echo "unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
